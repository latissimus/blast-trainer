# Kopiere diese Datei nach .env.local und trage die Werte deines Supabase-Projekts ein.
# .env.local wird NICHT eingecheckt (siehe .gitignore).
#
# Beide Werte sind bei Client-Apps oeffentlich (sie landen im Browser-Bundle).
# Der echte Schutz ist Row-Level-Security. Der service_role-Key gehoert NIEMALS hierher.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key
